{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "host": "127.0.0.1",
      "port": "5002",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ]
    }
  ],
  "emulators": {
    "firestore": {
      "port": 8081,
      "websocketPort": 9151
    },
    "functions": {
      "host": "127.0.0.1",
      "port": "5002"
    },
    "hub": {
      "port": 4401
    },
    "ui": {
      "enabled": true,
      "port": 4001
    },
    "eventarc": {
      "port": 9300
    },
    "tasks": {
      "port": 9500
    },
    "logging": {
      "port": 4501
    }
  }
}
